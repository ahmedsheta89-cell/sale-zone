{
  "name": "sale-zone-workers",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "test": "vitest run -c vitest.config.mjs",
    "preflight:gate": "npm run build && node dist/scripts/preflightGate.js",
    "detect:best-sha": "npm run build && node dist/scripts/detectBestSha.js",
    "rollout:safe": "npm run build && node dist/scripts/rolloutSafe.js",
    "start": "npm run build && node dist/bootstrap.js",
    "watchdog": "npm run build && node dist/watchdog/paranoid-monitor.js --daemon"
  },
  "dependencies": {
    "bullmq": "^5.58.0",
    "ioredis": "^5.4.1",
    "pino": "^9.5.0",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@types/node": "^22.10.2",
    "@types/semver": "^7.5.8",
    "semver": "^7.6.3",
    "testcontainers": "^10.16.0",
    "tsx": "^4.19.2",
    "typescript": "^5.6.3",
    "vitest": "^2.1.8"
  }
}
